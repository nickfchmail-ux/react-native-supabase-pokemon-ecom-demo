{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "lib": ["es2022", "dom"],
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "lib/data-service.js"
  ]
}
